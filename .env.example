# MCPBasket local configuration
# Copy to .env and adjust paths for your machine.
# The MCP server and viewer must use the same absolute MCPBASKET_STORE_PATH.

MCPBASKET_PORT=4377
MCPBASKET_STORE_PATH=/absolute/path/to/mcpbasket/basket.json
MCPBASKET_BIND_HOST=127.0.0.1
MCPBASKET_VIEWER_URL=http://127.0.0.1:4377

# Optional: Hermes command for refinement dispatch (absolute path)
# MCPBASKET_REFINEMENT_HERMES_COMMAND=/usr/local/bin/hermes
