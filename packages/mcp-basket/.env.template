# Optional basket viewer configuration.
MCPBASKET_PORT=4377
MCPBASKET_STORE_PATH=.mcpbasket/basket.json
# Listener bind address. Keep the local default unless a deliberate LAN service is required.
MCPBASKET_BIND_HOST=127.0.0.1
# Public base for the local MCP viewer/API if it is exposed through a tunnel.
# MCPBASKET_PUBLIC_HOST=https://your-tunnel.example.com

# Hosted browser UI that reads from the local/tunneled API using ?source=...
MCPBASKET_HOSTED_VIEWER_URL=https://mcpbasket.gordo.design
